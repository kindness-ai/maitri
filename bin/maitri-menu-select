#!/bin/bash

# maitri:summary=Pick one option with Walker
# maitri:group=menu
# maitri:name=select
# maitri:args=prompt option... [-- walker args...]
# maitri:examples=maitri menu select Format jpg png|maitri-menu-select Resolution 4k 1080p 720p -- --width 400

set -euo pipefail

if (( $# < 2 )); then
  echo "Usage: maitri-menu-select <prompt> <option>... [-- walker args...]" >&2
  exit 1
fi

prompt="$1"
shift

options=()
walker_args=()

while (( $# > 0 )); do
  if [[ $1 == "--" ]]; then
    shift
    walker_args=("$@")
    break
  fi

  options+=("$1")
  shift
done

if (( ${#options[@]} == 0 )); then
  echo "Usage: maitri-menu-select <prompt> <option>... [-- walker args...]" >&2
  exit 1
fi

printf '%s\n' "${options[@]}" | vicinae dmenu -p "$prompt…" 2>/dev/null
