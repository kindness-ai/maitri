#!/bin/bash

# maitri:summary=Install Steam and graphics drivers selected for this system
# maitri:requires-sudo=true

set -e

echo "Installing Steam..."
maitri-pkg-add steam
maitri-install-gaming-gpu-lib32

echo ""
echo "Steam will start automatically now. This might take a while..."

setsid gtk-launch steam >/dev/null 2>&1 &
