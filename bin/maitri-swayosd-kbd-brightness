#!/bin/bash

# maitri:summary=Display keyboard brightness level using SwayOSD on the current monitor.
# maitri:args=<0-100>
# maitri:examples=maitri swayosd kbd brightness 0 | maitri swayosd kbd brightness 50 | maitri swayosd kbd brightness 100

percent="$1"

progress="$(awk -v p="$percent" 'BEGIN{printf "%.2f", p/100}')"
[[ $progress == "0.00" ]] && progress="0.01"

maitri-swayosd-client \
  --custom-icon keyboard-brightness-symbolic \
  --custom-progress "$progress" \
  --custom-progress-text "${percent}%"
