#!/bin/bash

# maitri:summary=Install VS Code and configure maitri defaults for secrets, updates, and theme

echo "Installing VSCode..."
maitri-pkg-add visual-studio-code-bin

mkdir -p ~/.vscode ~/.config/Code/User

# Pre-populate argv.json with all keys VSCode expects so it doesn't overwrite on
# first launch and clobber the password-store setting.
cat > ~/.vscode/argv.json << EOF
{
  "password-store": "gnome-libsecret",
  "enable-crash-reporter": true,
  "crash-reporter-id": "$(uuidgen)"
}
EOF

# Ensure VSC's own auto-update feature is turned off
printf '{\n  "update.mode": "none"\n}\n' > ~/.config/Code/User/settings.json

# Apply maitri theme to VSCode
maitri-theme-set-vscode

setsid gtk-launch code
