#!/bin/bash

# maitri:summary=Log out after closing application windows
# maitri:examples=maitri logout | maitri system logout
# maitri:aliases=maitri logout

nohup bash -c "sleep 2 && uwsm stop" >/dev/null 2>&1 &

# Now close all windows
maitri-hyprland-window-close-all
sleep 1 # Allow apps like Chrome to shutdown correctly
