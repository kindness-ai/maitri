#!/bin/bash

# maitri:summary=Manage persistent state files for maitri toggles and settings.
# maitri:args=<set|clear> <state-name-or-pattern>
# maitri:hidden=true

STATE_DIR="$HOME/.local/state/maitri"
mkdir -p "$STATE_DIR"

COMMAND="$1"
STATE_NAME="$2"

if [[ -z $COMMAND ]]; then
  echo "Usage: maitri-state <set|clear> <state-name-or-pattern>"
  exit 1
fi

if [[ -z $STATE_NAME ]]; then
  echo "Usage: maitri-state $COMMAND <state-name>"
  exit 1
fi

case "$COMMAND" in
set) touch "$STATE_DIR/$STATE_NAME" ;;
clear) find "$STATE_DIR" -maxdepth 1 -type f -name "$STATE_NAME" -delete ;;
esac
