#!/bin/bash

# maitri:summary=Reinstall all default maitri packages from the stable channel
# maitri:requires-sudo=true

set -e

# Reinstall all default maitri packages from the stable channel and downgrade any packages that are too new.

# Set the package repository to the stable mirrors
maitri-refresh-pacman

# Downgrade any packages to the stable setup
sudo pacman -Suu --noconfirm

# Ensure all packages are installed
mapfile -t packages < <(grep -v '^#' "$MAITRI_PATH/install/maitri-base.packages" | grep -v '^$')
sudo pacman -Syu --noconfirm --needed "${packages[@]}"
