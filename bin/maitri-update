#!/bin/bash

# maitri:summary=Update maitri and system packages
# maitri:args=[-y]
# maitri:examples=maitri update | maitri update -y
# maitri:requires-sudo=true

set -e

# Run the update inside a PTY so pacman/yay keep showing download progress
# while still logging the full session for later analysis.
if [[ -z $MAITRI_UPDATE_LOGGED ]]; then
  script_command=$(printf '%q ' "$0" "$@")
  exec env MAITRI_UPDATE_LOGGED=1 script -qefc "$script_command" "/tmp/maitri-update.log"
fi

trap 'echo ""; echo -e "\033[0;31mSomething went wrong during the update!\n\nPlease review the output above carefully, correct the error, and retry the update.\n\nIf you need assistance, get help from the community at https://github.com/kindness-ai/maitri/issues\033[0m"' ERR

if [[ $1 == "-y" ]] || maitri-update-confirm; then
  maitri-snapshot create || (($? == 127))
  maitri-update-git
  maitri-update-perform
fi
