#!/bin/bash

# maitri:summary=Watch Hyprland monitor events and recover monitor toggles when a monitor is removed

SOCKET="$XDG_RUNTIME_DIR/hypr/$HYPRLAND_INSTANCE_SIGNATURE/.socket2.sock"

socat -U - "UNIX-CONNECT:$SOCKET" | while read -r event; do
  case "$event" in
    monitorremoved\>\>*|monitorremovedv2\>\>*)
      maitri-hyprland-monitor-internal recover
      maitri-hyprland-monitor-internal-mirror recover
      ;;
  esac
done
