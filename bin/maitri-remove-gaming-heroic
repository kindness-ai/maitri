#!/bin/bash

# maitri:summary=Remove Heroic Games Launcher and its game libraries, configs, and caches.
# maitri:requires-sudo=true

set -e

maitri-pkg-drop heroic-games-launcher-bin

rm -rf \
  "$HOME/.config/heroic" \
  "$HOME/.local/share/heroic" \
  "$HOME/.cache/heroic" \
  "$HOME/Games/Heroic"

echo ""
echo "Heroic and its data have been removed."
