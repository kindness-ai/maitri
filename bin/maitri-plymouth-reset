#!/bin/bash

# maitri:summary=Restore the default maitri Plymouth boot theme and SDDM login screen
# maitri:requires-sudo=true

theme_dir="/usr/share/plymouth/themes/maitri"

sudo find ~/.local/share/maitri/default/plymouth -maxdepth 1 -type f -exec cp -t "$theme_dir/" {} +
sudo plymouth-set-default-theme maitri

if maitri-cmd-present limine-mkinitcpio; then
  sudo limine-mkinitcpio
else
  sudo mkinitcpio -P
fi

maitri-refresh-sddm
