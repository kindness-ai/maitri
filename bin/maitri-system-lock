#!/bin/bash

# maitri:summary=Lock the computer and turn off the display
# maitri:group=system
# maitri:name=lock
# maitri:examples=maitri system lock

if ! pidof hyprlock >/dev/null; then
  (
    hyprlock
    maitri-system-wake
  ) &
fi

# Set keyboard layout to default (first layout)
hyprctl switchxkblayout all 0 > /dev/null 2>&1

# Ensure 1password is locked
if pgrep -x "1password" >/dev/null; then
  1password --lock &
fi

# Avoid running screensaver when locked
pkill -f org.maitri.screensaver

if [[ ${MAITRI_LOCK_ONLY:-false} != "true" ]]; then
  (
    sleep 3
    pidof hyprlock >/dev/null || exit 0
    maitri-brightness-keyboard off
    maitri-brightness-display off
  ) &
fi
