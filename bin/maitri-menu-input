#!/bin/bash

# maitri:summary=Prompt for text input with Walker
# maitri:group=menu
# maitri:name=input
# maitri:args=prompt [walker args...]
# maitri:examples=maitri menu input Reminder|maitri-menu-input "Reminder in minutes" --width 400

set -euo pipefail

prompt="${1:-Input}"
if (( $# > 0 )); then
  shift
fi

maitri-launch-walker --dmenu --inputonly --width 295 --minheight 1 --maxheight 1 -p "$prompt…" "$@" 2>/dev/null
