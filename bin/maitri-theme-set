#!/bin/bash

# maitri:summary=Apply an maitri theme
# maitri:args=<theme-name>
# maitri:examples=maitri theme list | maitri theme set "Spark"

if [[ -z $1 ]]; then
  echo "Usage: maitri-theme-set <theme-name>"
  exit 1
fi

CURRENT_THEME_PATH="$HOME/.config/maitri/current/theme"
NEXT_THEME_PATH="$HOME/.config/maitri/current/next-theme"
USER_THEMES_PATH="$HOME/.config/maitri/themes"
MAITRI_THEMES_PATH="$MAITRI_PATH/themes"

THEME_NAME=$(echo "$1" | sed -E 's/<[^>]+>//g' | tr '[:upper:]' '[:lower:]' | tr ' ' '-')

if [[ ! -d $MAITRI_THEMES_PATH/$THEME_NAME ]] && [[ ! -d $USER_THEMES_PATH/$THEME_NAME ]]; then
  echo "Theme '$THEME_NAME' does not exist"
  exit 1
fi

# Setup clean next theme directory (for atomic theme config swapping)
rm -rf "$NEXT_THEME_PATH"
mkdir -p "$NEXT_THEME_PATH"

# Copy official theme first, then overlay user customizations on top
cp -r "$MAITRI_THEMES_PATH/$THEME_NAME/"* "$NEXT_THEME_PATH/" 2>/dev/null
cp -r "$USER_THEMES_PATH/$THEME_NAME/"* "$NEXT_THEME_PATH/" 2>/dev/null

# Generate colors.toml from alacritty.toml if theme is missing colors.toml
if [[ ! -f $NEXT_THEME_PATH/colors.toml && -f $NEXT_THEME_PATH/alacritty.toml ]]; then
  maitri-theme-colors-from-alacritty "$NEXT_THEME_PATH"
fi

# Generate dynamic configs
maitri-theme-set-templates

# Swap next theme in as current
rm -rf "$CURRENT_THEME_PATH"
mv "$NEXT_THEME_PATH" "$CURRENT_THEME_PATH"

# Store theme name for reference
echo "$THEME_NAME" >"$HOME/.config/maitri/current/theme.name"

# Change background with theme
if [[ $MAITRI_THEME_SKIP_BACKGROUND != "1" ]]; then
  maitri-theme-bg-next
fi

# Restart components to apply new theme
if pgrep -x waybar >/dev/null; then
  maitri-restart-waybar
fi
maitri-restart-swayosd
maitri-restart-terminal
maitri-restart-hyprctl
maitri-restart-btop
maitri-restart-opencode
maitri-restart-mako
maitri-restart-helix

# Change app-specific themes
maitri-theme-set-foot
maitri-theme-set-gnome
maitri-theme-set-browser
maitri-theme-set-vscode
maitri-theme-set-obsidian
maitri-theme-set-keyboard
maitri-theme-set-warp
maitri-theme-set-sublime

# Call hook on theme set
maitri-hook theme-set "$THEME_NAME" >/dev/null
