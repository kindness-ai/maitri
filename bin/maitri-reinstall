#!/bin/bash

# maitri:summary=Reinstall maitri packages and reset default configs
# maitri:requires-sudo=true

set -e

# Attempt to reinstall all default maitri packages and reset all the default configs.

echo -e "This will reinstall all the default maitri packages and reset all default configs.\nWarning: All user changes to configs will be lost.\n"

if gum confirm "Are you sure you want to reinstall and lose all config changes?"; then
  maitri-reinstall-git
  maitri-reinstall-pkgs
  maitri-reinstall-configs

  gum confirm "System has been reinstalled. Reboot?" && maitri-system-reboot
fi
