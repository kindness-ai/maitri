#!/bin/bash

# maitri:summary=Switch maitri branches and update from the selected branch
# maitri:args=<branch>

set -e

if (($# == 0)); then
  echo "Usage: maitri-update-branch [main|dev]"
  exit 1
fi

branch="$1"

# Snapshot before switching branch
maitri-snapshot create || (( $? == 127 ))

if ! git -C "$MAITRI_PATH" diff --quiet || ! git -C "$MAITRI_PATH" diff --cached --quiet; then
  stashed=true
  git -C "$MAITRI_PATH" stash push -u -m "Autostash before switching to $branch"
else
  stashed=false
fi

# Switch branches
git -C "$MAITRI_PATH" switch "$branch"

# Reapply stash if we made one
if [[ $stashed == "true" ]]; then
  if ! git -C "$MAITRI_PATH" stash pop; then
    echo "⚠️ Conflicts when applying stash — stash kept"
  fi
fi

# Update the system from the new branch
maitri-update-perform
