#!/bin/bash

# maitri:summary=Toggle the Vicinae launcher, starting its server if needed

# The server is normally managed by vicinae.service, but make sure it is up so
# the very first keypress after login still works.
if ! vicinae ping >/dev/null 2>&1; then
  setsid uwsm-app -- vicinae server >/dev/null 2>&1 &
  for _ in {1..10}; do
    vicinae ping >/dev/null 2>&1 && break
    sleep 0.1
  done
fi

# Default to toggling the main window; allow passing a deeplink (e.g.
# vicinae://launch/emoji) or any vicinae subcommand for future keybinds.
if (( $# > 0 )); then
  exec vicinae "$@"
else
  exec vicinae toggle
fi
