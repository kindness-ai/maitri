#!/bin/bash

# maitri:summary=Install the maitri Vicinae extension into the user's extensions dir

# Installs the maitri Vicinae extension so the menu/keybindings commands resolve
# (vicinae://launch/@kindness-ai/maitri/<command>). No Node toolchain required.
#
# Prefers the packaged bundle shipped via the [maitri] channel
# (/usr/share/maitri/vicinae-extension), so this works on an offline install. Falls
# back to fetching a prebuilt GitHub release when the package isn't present (e.g. dev
# machines running maitri straight from a checkout, or to pull a newer build).
#
# GitHub fallback assumptions (match the vicinae-maitri release workflow):
# - Repo: kindness-ai/vicinae-maitri
# - Release asset: maitri-vicinae-extension.tar.gz (unpacks directly into the target
#   dir: package.json + *.js + assets/) plus a .sha256 checksum asset.

if maitri-cmd-missing vicinae; then
  exit 0
fi

DEST="$HOME/.local/share/vicinae/extensions/maitri"
SYSTEM_SRC="/usr/share/maitri/vicinae-extension"

# Clean-replace $DEST with the contents of $1 (a dir holding package.json + *.js + assets/).
install_from_dir() {
  rm -rf "$DEST"
  mkdir -p "$DEST"
  cp -a "$1/." "$DEST/"
  # Manifest changes need a restart before the new commands are indexed.
  maitri-restart-vicinae
}

# Preferred path: the packaged bundle (offline-capable, ships with the system).
if [[ -f "$SYSTEM_SRC/package.json" ]]; then
  install_from_dir "$SYSTEM_SRC"
  exit 0
fi

# Fallback: fetch a prebuilt release from GitHub (needs network).
REPO="kindness-ai/vicinae-maitri"
ASSET="maitri-vicinae-extension.tar.gz"
CURL_URL="https://github.com/$REPO/releases/latest/download/$ASSET"

TMP_DIR=$(mktemp -d)
trap 'rm -rf "$TMP_DIR"' EXIT

download_failed() {
  echo "maitri: could not fetch the Vicinae extension ($ASSET); skipping." >&2
  echo "maitri: the maitri menu/keybind commands stay inactive until it installs." >&2
  exit 0
}

# Prefer the authenticated gh path (works while the repo is private); fall back
# to a plain curl of the public latest-release URL.
if maitri-cmd-present gh; then
  if ! gh release download --repo "$REPO" --pattern "$ASSET*" --dir "$TMP_DIR" &>/dev/null; then
    download_failed
  fi
else
  if ! curl -fsSL -o "$TMP_DIR/$ASSET" "$CURL_URL"; then
    download_failed
  fi
  curl -fsSL -o "$TMP_DIR/$ASSET.sha256" "$CURL_URL.sha256" &>/dev/null || true
fi

if [[ ! -f "$TMP_DIR/$ASSET" ]]; then
  download_failed
fi

# Verify the checksum when the release ships one.
if [[ -f "$TMP_DIR/$ASSET.sha256" ]]; then
  if ! (cd "$TMP_DIR" && sha256sum --check --status "$ASSET.sha256"); then
    echo "maitri: Vicinae extension checksum mismatch; skipping." >&2
    exit 0
  fi
fi

# Unpack into a staging dir first so a bad tarball never clobbers a good install.
STAGE="$TMP_DIR/stage"
mkdir -p "$STAGE"
if ! tar -xzf "$TMP_DIR/$ASSET" -C "$STAGE"; then
  echo "maitri: Vicinae extension archive could not be unpacked; skipping." >&2
  exit 0
fi

install_from_dir "$STAGE"
