# Changes require a restart to take effect.

# Ensure maitri bins are in the path
export MAITRI_PATH=$HOME/.local/share/maitri
export PATH=$MAITRI_PATH/bin:$PATH:$HOME/.local/bin

# Set default terminal and editor
source ~/.config/uwsm/default

# Activate mise if present on the system
maitri-cmd-present mise && eval "$(mise activate bash --shims)"
